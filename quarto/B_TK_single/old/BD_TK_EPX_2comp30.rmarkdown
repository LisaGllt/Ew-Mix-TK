p_post <- ggplot() +
  
  # Priors
  stat_halfeye(
    data = df_priors_dist,
    aes(
       x = samples,
       #y = ..scaled..
       ),
    alpha = alpha_prior,
    fill = col_prior,
    color = col_prior,
    normalize = "xy"
