    Time_point_days = paste0(Time_point_f, " days"),
    Time_point_days = fct_reorder(Time_point_days, as.numeric(Time_point))
    )

df_mod_CiEPX_ind_t_plot <- subset(df_mod_CiEPX_ind_t, ID %in% ID_tri) |> 
  mutate(
    No_rep = paste0("No ", Nb_rep),
    Time_point = as.numeric(gsub("([0-9]+).*", "\\1" , as.character(Time_point_f))),
    Time_point_days = paste0(Time_point_f, " days"),
    Time_point_days = fct_reorder(Time_point_days, as.numeric(Time_point))
  )

df_mod_CeEPX_ind_t_plot <- subset(df_mod_CeEPX_ind_t, ID %in% ID_tri)
df_mod_Weight_ind_t_plot <- subset(df_mod_Weight_ind_t, ID %in% ID_tri) |> 
  mutate(
    No_rep = paste0("No ", Nb_rep),
    Time_point = as.numeric(gsub("([0-9]+).*", "\\1" , as.character(Time_point_f))),
    Time_point_days = paste0(Time_point_f, " days"),
    Time_point_days = fct_reorder(Time_point_days, as.numeric(Time_point))
  )

df_phases_plot <- subset(df_phases, ID %in% ID_tri)|> 
  left_join(Time_points_Nb_rep, by="ID") |> 
  mutate(
    No_rep = paste0("No ", Nb_rep),
    Time_point = as.numeric(gsub("([0-9]+).*", "\\1" , as.character(Time_point_f))),
    Time_point_days = paste0(Time_point_f, " days"),
    Time_point_days = fct_reorder(Time_point_days, as.numeric(Time_point))
    )

alpha_point <- 0.5
col_exposure <- c(Nord_aurora[2], Nord_aurora[3], Nord_aurora[4])

p_CiEPX_traj <- ggplot()+
  
  geom_segment(
    data = df_phases_plot,
    aes(
      x = t_start,
      xend = t_end,
      y = y,
      yend = y,
      group = ID,
      color = factor(Phase)
    ),
    linewidth = 2,
    alpha = 0.7
  ) +

  geom_line(
    data=df_mod_CiEPX_ind_t_plot,
    aes(
      x=Time,
      y= low,
      group = ID
      ),
    linetype="dotted",
    color = col_EPX
    )+
  geom_line(
    data=df_mod_CiEPX_ind_t_plot,
    aes(
      x=Time,
      y= up,
      group = ID
      ),
    linetype="dotted",
    color = col_EPX
    )+
  geom_line(
    data=df_mod_CiEPX_ind_t_plot,
    aes(
      x=Time,
      y= predict.endpoint,
      group = ID
      ),
    color = col_EPX,
    lwd=1
    )+
  geom_ribbon(
    data=df_mod_CiEPX_ind_t_plot,
    aes(
      x=Time,
      ymax= up,
      ymin= low,
      group = ID
      ),
    fill = col_EPX,
    alpha=0.1
    )+
  geom_point(
    data = dObs_ind_plot,
    aes(
      x = Time,
      y = CiEPX_obs
    ),
    size = 2,
    alpha = 0.7,
    color = col_red
  )+
  # facet_wrap(
  #   ~ID,
  #   ncol=4,
  #   #scales = "free_x"
  #   )+
  facet_grid(
    vars(Time_point_days), vars(No_rep)#,
    )+
  scale_color_manual(
    values = col_exposure,
    label = c("Uptake", "Elimination", "Depuration"),
    name = "Phase"
    )+
  labs(
    x = "Time (days)",
    y = "CiEPX (ng/g)"
  )+
  #lims(y=c(0, 300))+
  theme_minimal()
  

p_CiEPX_traj 

