We can also take a look at the likelihood and the deviance ratio.




```{r EPXlike, message=F, warning=F}
#| fig-cap: Evolution of likelihood and deviance ratio through the iterations.
#| label: fig-EPXlike
#| fig-height: 4
#| fig-width: 8

p1 <- ggplot(
  MCMC_out_EPX$df_LnPost_start, 
  aes(
    x = iteration, 
    y = LnPosterior, 
    color = Chain
    )
  ) +
  geom_line() +
  scale_color_manual(name = "Chains", label = c("1", "2", "3"), values = Nord_frost) +
  labs(
    x = "First half iterations", 
    y = "LnPosterior"
    ) +
  theme_minimal()

p2 <- ggplot(
  MCMC_out_EPX$df_LnPost |> filter(iteration!=1), 
  aes(
    x = iteration, 
    y = LnPosterior, 
    color = Chain
    )
  ) +
  geom_line() +
  scale_color_manual(name = "Chains", label = c("1", "2", "3"), values = Nord_frost) +
  labs(
    x = paste(MCMC_out_EPX$Nb_iter_kept, "last iterations"), 
    y = "LnPosterior"
    ) +
  theme_minimal()

p3 <- ggplot(
  MCMC_out_EPX$df_Devc |> filter(iteration!=1), 
  aes(
    x = iteration, 
    y = RatioDeviance, 
    color = Chain
    )
  ) +
  geom_line() +
  scale_color_manual(name = "Chains", label = c("1", "2", "3"), values = Nord_frost) +
  labs(
    x = paste(MCMC_out_EPX$Nb_iter_kept, "last iterations"), 
    y = "Ratio Deviance"
    ) +
  theme_minimal()

p_LL <- p1 + p2 + p3 +
  plot_layout(ncol=3, guides = "collect")
p_LL

