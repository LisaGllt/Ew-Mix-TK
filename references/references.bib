@article{loureiro_2011,
  title = {Performance of Standard Media in Toxicological Assessments with {{Daphnia}} Magna: Chelators and Ionic Composition versus Metal Toxicity},
  shorttitle = {Performance of Standard Media in Toxicological Assessments with {{Daphnia}} Magna},
