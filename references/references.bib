@article{diaz_2018,
  title = {Assessing Nature's Contributions to People},
  author = {Díaz, Sandra and Pascual, Unai and Stenseke, Marie and Martín-López, Berta and Watson, Robert T. and Molnár, Zsolt and Hill, Rosemary and Chan, Kai M. A. and Baste, Ivar A. and Brauman, Kate A. and Polasky, Stephen and Church, Andrew and Lonsdale, Mark and Larigauderie, Anne and Leadley, Paul W. and family=Oudenhoven, given=Alexander P. E., prefix=van, useprefix=true and family=Plaat, given=Felice, prefix=van der, useprefix=true and Schröter, Matthias and Lavorel, Sandra and Aumeeruddy-Thomas, Yildiz and Bukvareva, Elena and Davies, Kirsten and Demissew, Sebsebe and Erpul, Gunay and Failler, Pierre and Guerra, Carlos A. and Hewitt, Chad L. and Keune, Hans and Lindley, Sarah and Shirayama, Yoshihisa},
  date = {2018-01-19},
  journaltitle = {Science},
  shortjournal = {Science},
  volume = {359},
  number = {6373},
  pages = {270--272},
  issn = {0036-8075, 1095-9203},
  doi = {10.1126/science.aap8826},
  url = {https://www.science.org/doi/10.1126/science.aap8826},
  urldate = {2023-04-18},
  abstract = {Recognizing culture, and diverse sources of knowledge, can improve assessments           ,                             A major challenge today and into the future is to maintain or enhance beneficial contributions of nature to a good quality of life for all people. This is among the key motivations of the Intergovernmental Science-Policy Platform on Biodiversity and Ecosystem Services (IPBES), a joint global effort by governments, academia, and civil society to assess and promote knowledge of Earth's biodiversity and ecosystems and their contribution to human societies in order to inform policy formulation. One of the more recent key elements of the IPBES conceptual framework (               1               ) is the notion of nature's contributions to people (NCP), which builds on the ecosystem service concept popularized by the Millennium Ecosystem Assessment (MA) (               2               ). But as we detail below, NCP as defined and put into practice in IPBES differs from earlier work in several important ways. First, the NCP approach recognizes the central and pervasive role that culture plays in defining all links between people and nature. Second, use of NCP elevates, emphasizes, and operationalizes the role of indigenous and local knowledge in understanding nature's contribution to people.},
  langid = {english},
  keywords = {notion},
  file = {/Users/lisagollot/Zotero/storage/5BMIJNA8/Diaz et al., 2019 SI.pdf;/Users/lisagollot/Zotero/storage/7VTDMXQT/Díaz et al. - 2018 - Assessing nature's contributions to people.pdf}
}

