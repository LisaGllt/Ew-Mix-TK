  doi = {10.1016/j.scitotenv.2020.138194},
  urldate = {2023-10-20},
  abstract = {Drawing insights from multiple disciplines is essential for finding integrative solutions that are required to tackle complex environmental problems. Human activities are causing unprecedented influence on global ecosystems, culminating in the loss of species and fundamental changes in the selective environments of organisms across the tree of life. Our collective understanding about biological evolution can help identify and mitigate many of the environmental problems in the Anthropocene. To this end, we propose a stronger integration of environmental sciences with evolutionary biology.},
