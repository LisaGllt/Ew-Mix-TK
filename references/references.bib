  author = {Rollin, Marc and Coulaud, Romain and Rocher, Béatrice and Billoir, Elise and Geffard, Olivier and Duflot, Aurélie and Fromont, Chloé and Boulangé‐Lecomte, Céline and Le Foll, Frank and Xuereb, Benoit},
  date = {2023-04},
  journaltitle = {Environmental Toxicology and Chemistry},
  shortjournal = {Enviro Toxic and Chemistry},
