@article{amorim_2012,
  title = {Toxicity of Copper Nanoparticles and {{CuCl2}} Salt to {{{\emph{Enchytraeus}}}}{\emph{ Albidus}} Worms: {{Survival}}, Reproduction and Avoidance Responses},
  shorttitle = {Toxicity of Copper Nanoparticles and {{CuCl2}} Salt to {{{\emph{Enchytraeus}}}}{\emph{ Albidus}} Worms},
  author = {Amorim, M{\'o}nica Jo{\~a}o Barros and {Scott-Fordsmand}, Janeck James},
  year = 2012,
  month = may,
  journal = {Environmental Pollution},
  volume = {164},
  pages = {164--168},
  issn = {0269-7491},
  doi = {10.1016/j.envpol.2012.01.015},
  urldate = {2025-06-20},
  abstract = {Environmental effects of copper nanoparticles are little studied in terrestrial ecosystems. In the present article, the toxicity of copper nanoparticles (Cu-NP) on the enchytraeid Enchytraeus albidus is compared to the toxicity of a copper-salt (CuCl2). The effect parameters studied were survival, reproductive output and avoidance behaviour. The results show that Cu-NP were more toxic to E.~albidus than the same concentrations of the CuCl2-salt. The physic-chemical analysis of the particles indicated that only a small fraction was released as ions. Hence, the results indicated a nanoparticle-specific effect -- lower reproductive output and higher avoidance. This was observed as 2--8 fold (significant) lower ECx values for Cu-NP (EC50-reprod~=~95~mg Cu/kg; EC50-avoid~=~241~mg Cu/kg) exposed organisms compared to CuCl2 (EC50-reprod~=~251~mg Cu/kg; EC50-avoid~=~475~mg Cu/kg) exposed organisms. These results corroborate with a nanoparticle-specific effect.},
  keywords = {Copper nanoparticles,Copper salt,Effect assessment,Enchytraeids},
  file = {/Users/lisagollot/Zotero/storage/BXFA2GX9/S0269749112000322.html}
}

