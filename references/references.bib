  author = {Shekhovtsov, Sergei V. and Ermolov, Sergei A. and Poluboyarova, Tatiana V. and {Kim-Kashmenskaya}, Maria N. and Derzhinsky, Yevgeniy A. and Peltek, Sergey E.},
  year = 2021,
