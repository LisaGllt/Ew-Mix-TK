  title = {{Oxydation biologique et chimique \`a l'ozone des micropolluants \'emergents en station d'\'epuration}},
  author = {{Gonzalez-Ospina}, Adriana and Domenjoud, Bruno and Vulliet, Emmanuelle and Bony, Sylvie and Baig, Sylvie},
