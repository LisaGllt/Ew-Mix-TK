@article{jager_2023a,
  title = {Using the Standard {{DEB}} Animal Model for Toxicokinetic-Toxicodynamic Analysis},
  author = {Jager, Tjalling and Goussen, Benoit and Gergs, André},
  date = {2023-01},
  journaltitle = {Ecological Modelling},
