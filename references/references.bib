  shorttitle = {Modelling the Accumulation of Hydrophobic Organic Chemicals in Earthworms},
  author = {Belfroid, Ang{\'e}lique C. and Scinen, Willem and Van Gestel, Kees C. A. M. and Hermens, Joop L. M. and Van Leeuwen, Kees J.},
