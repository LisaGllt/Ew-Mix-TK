@article{efsascientificcommittee_2019,
  title = {Guidance on Harmonised Methodologies for Human Health, Animal Health and Ecological Risk Assessment of Combined Exposure to Multiple Chemicals},
  author = {{EFSA Scientific Committee} and More, Simon John and Bampidis, Vasileios and Benford, Diane and Bennekou, Susanne Hougaard and Bragard, Claude and Halldorsson, Thorhallur Ingi and Hern{\'a}ndez-Jerez, Antonio F and Koutsoumanis, Konstantinos and Naegeli, Hanspeter and Schlatter, Josef R and Silano, Vittorio and Nielsen, S{\o}ren Saxmose and Schrenk, Dieter and Turck, Dominique and Younes, Maged and Benfenati, Emilio and Castle, Laurence and Cedergreen, Nina and Hardy, Anthony and Laskowski, Ryszard and Leblanc, Jean Charles and Kortenkamp, Andreas and Ragas, Ad and Posthuma, Leo and Svendsen, Claus and Solecki, Roland and Testai, Emanuela and Dujardin, Bruno and Kass, George EN and Manini, Paola and Jeddi, Maryam Zare and Dorne, Jean-Lou CM and Hogstrand, Christer},
