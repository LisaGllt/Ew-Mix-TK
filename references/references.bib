@article{kjaerstad_2010,
  title = {Endocrine Disrupting Effects in Vitro of Conazole Antifungals Used as Pesticides and Pharmaceuticals},
  author = {Kjærstad, Mia B. and Taxvig, Camilla and Nellemann, Christine and Vinggaard, Anne Marie and Andersen, Helle R.},
  date = {2010-12},
