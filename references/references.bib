@article{pery_2002,
  title = {A Modeling Approach to Link Food Availability, Growth, Emergence, and Reproduction for the Midge {{{\mkbibemph{Chironomus}}}}{\mkbibemph{ Riparius}}},
  author = {Péry, Alexandre R. R. and Mons, Raphaël and Flammarion, Patrick and Lagadic, Laurent and Garric, Jeanne},
  date = {2002-11},
  journaltitle = {Environmental Toxicology and Chemistry},
  shortjournal = {Environ Toxicol Chem},
  volume = {21},
