@article{qiu_2014,
  title = {Modeling Cadmium and Nickel Toxicity to Earthworms with the Free Ion Approach},
  author = {Qiu, Hao and Vijver, Martina G. and Van Gestel, Cornelis A.M. and He, Erkai and Peijnenburg, Willie J.G.M.},
  year = 2014,
  month = feb,
  journal = {Environmental Toxicology and Chemistry},
  volume = {33},
  number = {2},
  pages = {438--446},
  issn = {0730-7268, 1552-8618},
  doi = {10.1002/etc.2454},
  urldate = {2024-06-28},
  abstract = {Abstract                                                            The use of the free ion approach to quantify the toxic effects of Cd and Ni to the earthworms                 Lumbricus rubellus                 and                 Aporrectodea longa                 exposed in soils of different types was explored. Median lethal concentration (LC50) of Cd (expressed as the total concentration in soil) varied by approximately 11-fold and 28-fold for                 L. rubellus                 and                 A. longa                 , respectively. For Ni, these values were 50-fold and 38-fold, respectively. For the 2 earthworm species, no significant influence of cations (H                 +                 , Ca                 2+                 , Mg                 2+                 , K                 +                 , and Na                 +                 ) on Cd                 2+                 toxicity was observed, while Mg                 2+                 was found to significantly alleviate Ni                 2+                 toxicity. The free ion activity model, which is a special case of the free ion approach with no impact of cations, sufficiently described the variability in Cd                 2+                 toxicity across soils but failed in predicting Ni                 2+                 toxicity. The free ion approach, in which the protective effects of Mg                 2+                 were included, explained 89\% and 84\% of the variations in LC50\textbraceleft Ni                 2+                 \textbraceright{} (expressed as free ion activity) for                 L. rubellus                 (log LC50\textbraceleft Ni                 2+                 \textbraceright\,=\,1.18log\textbraceleft Mg                 2+                 \textbraceright -0.52) and                 A. longa                 (log LC50\textbraceleft Ni                 2+                 \textbraceright\,=\,0.51log\textbraceleft Mg                 2+                 \textbraceright -2.16), respectively. Prediction error was within a factor of 2 for both Cd                 2+                 and Ni                 2+                 toxicity, indicating the applicability of the free ion approach for predicting toxicity of these 2 metals. Although extrapolation of the free ion approach across metals still needs more research efforts, this approach, as an alternative to the biotic ligand model, provides a feasible framework for site-specific risk assessment.                 Environ Toxicol Chem                 2014;33:438--446. \copyright{} 2013 SETAC},
  langid = {english},
  file = {/Users/lisagollot/Zotero/storage/VVAIFN43/Qiu et al. - 2014 - Modeling cadmium and nickel toxicity to earthworms.pdf}
}

@article{rakel_2020,
  title = {Individual-Based Dynamic Energy Budget Modelling of Earthworm Life-Histories in the Context of Competition},
  author = {Rakel, Kim J. and Preuss, Thomas G. and Gergs, Andr{\'e}},
  year = 2020,
  month = sep,
  journal = {Ecological Modelling},
  volume = {432},
  pages = {109222},
  issn = {03043800},
  doi = {10.1016/j.ecolmodel.2020.109222},
  urldate = {2023-02-21},
  abstract = {In the environmental risk assessment of chemicals, ecological modelling can facilitate the quantification of specific protection goals, for instance by the extrapolation of untested situations from toxicity test results. In particular, individual-based models (IBMs) are gaining resonance in the regulatory community as a mean to predict how populations perform under environmental perturbation. In this regard, the hope is that standardised or general designs will increase the applicability and acceptance of model based risk assessments. Strong moves in the direction of generalised IBM designs have been made based on metabolic theories such as the dynamic energy budget (DEB) theory. Here, we parameterise the standard DEB model for the earthworm Eisenia fetida and test the individual-based DEB model by comparing predictions with published data on life-histories measured for individual worms and populations. Overall, the comparison showed good agreement between the simulations and the data, suggesting that the standard DEB model, more precisely DEBs `kappa-rule', characterizing the energy partitioning between somatic and reproductive processes, is applicable to earthworms. The parametrized model is able to predict growth and reproduction for different food quality and availability.},
  langid = {english},
  keywords = {notion},
  file = {/Users/lisagollot/Zotero/storage/Z4ZSKB2A/Rakel et al. - 2020 - Individual-based dynamic energy budget modelling o.pdf}
}

