@article{gergs_2015,
  title = {Body Size-Dependent Toxicokinetics and Toxicodynamics Could Explain Intra- and Interspecies Variability in Sensitivity},
  author = {Gergs, Andr{\'e} and Kulkarni, Devdutt and Preuss, Thomas G.},
