@article{gottardi_2017,
  title = {The Effects of Epoxiconazole and {$\alpha$}-Cypermethrin on {{{\emph{Daphnia}}}}{\emph{ Magna}} Growth, Reproduction, and Offspring Size},
  author = {Gottardi, Michele and Birch, Michala Rosa and Dalhoff, Kristoffer and Cedergreen, Nina},
  year = 2017,
  month = feb,
  journal = {Environmental Toxicology and Chemistry},
  volume = {36},
  number = {8},
  pages = {2155--2166},
  issn = {0730-7268, 1552-8618},
  doi = {10.1002/etc.3752},
  urldate = {2025-07-01},
  abstract = {Abstract                            {$\quad$}               Two of the main classes of pesticides commonly used in agriculture are azole fungicides and pyrethroid insecticides. Because azoles have been shown to synergize the effect of pyrethroids, the effect of their mixture is of concern. The aim of the present study was to investigate the effect of sublethal concentrations of epoxiconazole and {$\alpha$}-cypermethrin and their mixture on growth, reproduction, and in vivo cytochrome P450 activity of the aquatic crustacean Daphnia magna over 42 d. Continuous exposure to nonlethal concentrations of {$\alpha$}-cypermethrin at 20\,ng/L negatively affected adult growth and number and size of neonates within the first 14 d of exposure. Exposure to epoxiconazole at 25\,{$\mu$}g/L increased protein content of adults within 1 to 3 d after initiating exposure and increased cumulative number of offspring at exposure times \&gt;31 d. Epoxiconazole enhanced the negative effect of {$\alpha$}-cypermethrin up to 3-fold leading to decreased growth, cytochrome P450 activity, and reproduction of D. magna within the first 14 d of exposure. After 14 d, the synergistic interactions disappeared. The reported effects, although lacking direct negative consequence in the long term, might have cumulative toxicity with other stressors such as food scarcity, predation, and pathogens, posing an additional hazard for the organisms at the beginning of their life cycle. Environ Toxicol Chem 2017;36:2155--2166. \copyright{} 2017 SETAC},
  copyright = {https://academic.oup.com/pages/standard-publication-reuse-rights},
  langid = {english},
  file = {/Users/lisagollot/Zotero/storage/98GQQFTM/Gottardi et al. - 2017 - The effects of epoxiconazole and α-cypermethrin on Daphnia magna growth, reproduction, and of.pdf}
}

