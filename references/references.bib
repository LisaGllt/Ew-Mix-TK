@article{goussen_2015,
  title = {Energy-Based Modelling to Assess Effects of Chemicals on {{Caenorhabditis}} Elegans: {{A}} Case Study on Uranium},
  shorttitle = {Energy-Based Modelling to Assess Effects of Chemicals on {{Caenorhabditis}} Elegans},
  author = {Goussen, Benoit and Beaudouin, Rémy and Dutilleul, Morgan and Buisset-Goussen, Adeline and Bonzom, Jean-Marc and Péry, Alexandre R.R.},
  date = {2015-02},
  journaltitle = {Chemosphere},
  shortjournal = {Chemosphere},
  volume = {120},
  pages = {507--514},
  issn = {00456535},
  doi = {10.1016/j.chemosphere.2014.09.006},
  url = {https://linkinghub.elsevier.com/retrieve/pii/S0045653514010662},
  urldate = {2023-08-12},
  abstract = {The ubiquitous free-living nematode Caenorhabditis elegans is a powerful animal model for measuring the evolutionary effects of pollutants which is increasingly used in (eco) toxicological studies. Indeed, toxicity tests with this nematode can provide in a few days data on the whole life cycle. These data can be analysed with mathematical tools such as toxicokinetic-toxicodynamic modelling approaches. In this study, we assessed how a chronic exposure to a radioactive heavy metal (uranium) affects the life-cycle of C. elegans using a mechanistic model. In order to achieve this, we exposed individuals to a range of seven concentrations of uranium. Growth and reproduction were followed daily. These data were analysed with a model for nematodes based on the Dynamic Energy Budget theory, able to handle a wide range of plausible biological parameters values. Parameter estimations were performed using a Bayesian framework. Our results showed that uranium affects the assimilation of energy from food with a no-effect concentration (NEC) of 0.42 mM U which would be the threshold for effects on both growth and reproduction. The sensitivity analysis showed that the main contributors to the model output were parameters linked to the feeding processes and the actual exposure concentration. This confirms that the real exposure concentration should be measured accurately and that the feeding parameters should not be fixed, but need to be reestimated during the parameter estimation process.},
  langid = {english},
  file = {/Users/lisagollot/Zotero/storage/2Q6MR8PV/Goussen et al. - 2015 - Energy-based modelling to assess effects of chemic.pdf}
}

@article{goussen_2015a,
  title = {Transgenerational {{Adaptation}} to {{Pollution Changes Energy Allocation}} in {{Populations}} of {{Nematodes}}},
  author = {Goussen, Benoit and Péry, Alexandre R.R. and Bonzom, Jean-Marc and Beaudouin, Rémy},
  date = {2015-10-20},
  journaltitle = {Environmental Science \& Technology},
  shortjournal = {Environ. Sci. Technol.},
  volume = {49},
  number = {20},
  pages = {12500--12508},
  issn = {0013-936X, 1520-5851},
  doi = {10.1021/acs.est.5b03405},
  url = {https://pubs.acs.org/doi/10.1021/acs.est.5b03405},
  urldate = {2025-01-03},
  abstract = {Assessing the evolutionary responses of long-term exposed populations requires multigeneration ecotoxicity tests. However, the analysis of the data from these tests is not straightforward. Mechanistic models allow the in-depth analysis of the variation of physiological traits over many generations, by quantifying the trend of the physiological and toxicological parameters of the model. In the present study, a bioenergetic mechanistic model has been used to assess the evolution of two populations of the nematode Caenorhabditis elegans in control conditions or exposed to uranium. This evolutionary pressure resulted in a brood size reduction of 60\%. We showed an adaptation of individuals of both populations to experimental conditions (increase of maximal length, decrease of growth rate, decrease of brood size, and decrease of the elimination rate). In addition, differential evolution was also highlighted between the two populations once the maternal effects had been diminished after several generations. Thus, individuals that were greater in maximal length, but with apparently a greater sensitivity to uranium were selected in the uranium population. In this study, we showed that this bioenergetics mechanistic modeling approach provided a precise, certain, and powerful analysis of the life strategy of C. elegans populations exposed to heavy metals resulting in an evolutionary pressure across successive generations.},
  langid = {english},
  file = {/Users/lisagollot/Zotero/storage/6BSMAFL4/Goussen et al. - 2015 - Transgenerational Adaptation to Pollution Changes Energy Allocation in Populations of Nematodes.pdf}
}

@article{grassi_2022,
  title = {State of the Art of Triad-Based Ecological Risk Assessment: Current Limitations and Needed Implementations in the Case of Soil Diffuse Contamination},
  shorttitle = {State of the Art of Triad-Based Ecological Risk Assessment},
  author = {Grassi, Giacomo and Lamy, Isabelle and Pucheux, Nicolas and Ferrari, Benoit Jean Dominique and Faburé, Juliette},
  date = {2022-05-12},
  journaltitle = {Frontiers in Environmental Science},
  shortjournal = {Front. Environ. Sci.},
  volume = {10},
  pages = {878238},
  issn = {2296-665X},
  doi = {10.3389/fenvs.2022.878238},
  url = {https://www.frontiersin.org/articles/10.3389/fenvs.2022.878238/full},
  urldate = {2024-03-19},
  abstract = {Soils can be sinks of pollutant mixtures, whose effects on terrestrial ecosystems are not of obvious interpretation. Risk assessment is rather codified and many approaches can be used. Nevertheless, there are still uncertainties remaining when dealing with diffuse pollution, including chronic inputs of low, sublethal, concentrations of mixtures of micropollutants. In this paper, we reviewed through a comprehensive literature analysis one of the latest promising methodologies, the triad approach, in order to understand its area of application in terrestrial ecosystems, the ways of applicability and the reported actual usage. In the case of diffuse pollution, where all the criteria of the triad approach can differ in their indication, we show that some improvements have to be made in either the chemical, ecological or ecotoxicological approaches to be able to clearly identify the risk and to address the uncertainties linked to the low, sublethal contents of contaminants.},
  langid = {french},
  file = {/Users/lisagollot/Zotero/storage/3WSEZMXB/fenvs-10-878238.pdf}
}

@article{green_2013,
  title = {The Drive to Ban the {{NOEC}}/{{LOEC}} in Favor of {{ECx}} Is Misguided and Misinformed},
  author = {Green, John W and Springer, Timothy A and Staveley, Jane P},
  date = {2013},
  journaltitle = {Integrated Environmental Assessment and Management},
  volume = {9},
  number = {1},
  pages = {12--16},
  issn = {1551-3793},
  doi = {10.1002/ieam.1367},
  url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/ieam.1367},
  urldate = {2023-10-06},
  abstract = {Challenges to the use of the no observed effect concentration (NOEC) in ecotoxicology have appeared over the years, with a recent call for banning its use in favor of the x\% effects concentration (ECx). This article presents an opposing view, providing reasons for the continued use of the NOEC, and for hypothesis testing in general. Although the use of ECx values is appropriate in many situations, there are numerous real-world examples where it is not suitable and offers no advantage over the use of hypothesis testing. These examples are presented with recommended data analysis techniques, illustrating the variety of statistical approaches that are meaningful in analyzing ecotoxicity data. Thoughtful consideration of study design and proper analysis and interpretation of the results will go further to advance the science of ecotoxicology than attempting to implement a blanket prohibition or endorsement of any single statistical approach. Integr Environ Assess Manag 2013; 9: 12–16. © 2012 SETAC},
  langid = {english},
  keywords = {Ecotoxicology,ECx,Hypothesis testing,NOEC,Regression analysis,Statistics},
  file = {/Users/lisagollot/Zotero/storage/XUJUGQCZ/Green et al. - 2013 - The drive to ban the NOECLOEC in favor of ECx is .pdf;/Users/lisagollot/Zotero/storage/ASYLEZGV/ieam.html}
}

