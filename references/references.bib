@incollection{oziolor_2015,
  title = {Evolutionary {{Toxicology}}: {{Population Adaptation}} in {{Response}} to {{Anthropogenic Pollution}}},
  shorttitle = {Evolutionary {{Toxicology}}},
  booktitle = {Extremophile {{Fishes}}},
  author = {Oziolor, Elias M. and Matson, Cole W.},
