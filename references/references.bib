  shorttitle = {Growth of Hatchling Earthworms in the Presence of Adults},
  author = {Lowe, Christopher and Butt, Kevin},
  date = {2002-05-01},
  journaltitle = {Biology and Fertility of Soils},
  shortjournal = {Biology and Fertility of Soils},
  volume = {35},
