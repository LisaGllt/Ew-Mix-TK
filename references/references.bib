@article{bart_2019d,
  title = {Towards a Better Understanding of the Life Cycle of the Earthworm {{Aporrectodea}} Caliginosa: {{New}} Data and Energy-Based Modelling},
  shorttitle = {Towards a Better Understanding of the Life Cycle of the Earthworm {{Aporrectodea}} Caliginosa},
