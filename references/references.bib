@article{erfanifar_2018,
  title = {Acute {{Toxicity}} and the {{Effects Of Copper Sulphate}} [{{CuSo4}}.{{5H2O}}] on the {{Behavior}} of the {{Gray Mullet}} [{{Mugil Cephalus}}]},
  author = {Erfanifar, Elahe and Erfanifar, Elnaz and Kasalkhe, Naghimeh},
  year = 2018,
