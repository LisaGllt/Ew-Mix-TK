@article{garamszegi_2025,
  title = {A Density-Based Method to Objectively Quantify Earthworm Activity},
  author = {Garamszegi, Péter and Calogiuri, Tullia and Hagens, Mathilde and Vidal, Alix and Van Groenigen, Jan Willem},
  date = {2025-02},
  journaltitle = {Applied Soil Ecology},
  shortjournal = {Applied Soil Ecology},
  volume = {206},
  pages = {105771},
  issn = {09291393},
  doi = {10.1016/j.apsoil.2024.105771},
  url = {https://linkinghub.elsevier.com/retrieve/pii/S092913932400502X},
  urldate = {2025-01-09},
  abstract = {Earthworms are among the most important soil fauna. To exert effects on soils, they need to be active. Earthworm presence is often used as an indicator for activity, but this is not always reliable as earthworms may survive long periods of inactivity or even estivation. Other direct, reliable, and objective measurements for earthworm activity are lacking. Here, we present a novel earthworm activity measurement, based on body-density difference between actively feeding and inactive earthworms. The underlying principle is that active earthworms have a higher density as their gut is filled with soil particles, while inactive earthworms generally have an empty gut. The method therefore separates inactive earthworms from active ones by flotation. To achieve separation, a 1.08 g cm 3 sucrose solution is used. Since it is well established that earthworm activity is reduced in dry soil conditions, we set up a soil moisture gradient experiment to gain a range in earthworm activity. We tested our method on four common European earthworms (endogeic species Allolobophora chlorotica [Savigny] and Aporrectodea caliginosa [Savigny], anecic species Aporrectodea longa [Ude] and epigeic species Lumbricus rubellus [Hoffmeister]) in an experiment with three soil moisture levels (84, 126 and 168 mL kg 1) using a sandy topsoil. As additional proxy for earthworm activity, estivation was visually recorded. We found a high inter-method correlation between density-based and visually estimated earthworm activity, regardless of earthworm species and moisture treatment. Furthermore, our novel method detected inactive individuals of L. rubellus, a species without the ability of estivation. We demonstrated that our density-based method allows for easy and quick quantification of active earthworms. This method offers clear advantages over visual assessments of estivation or cast production, in particular objectivity and applicability to a wider range of species, including those that do not enter estivation.},
  langid = {english},
  file = {/Users/lisagollot/Zotero/storage/ALBPAUDC/Garamszegi et al. - 2025 - A density-based method to objectively quantify earthworm activity.pdf}
}

@article{garnier_2022,
