@article{ford_2021,
  title = {The {{Role}} of {{Behavioral Ecotoxicology}} in {{Environmental Protection}}},
  author = {Ford, Alex T. and Ågerstrand, Marlene and Brooks, Bryan W. and Allen, Joel and Bertram, Michael G. and Brodin, Tomas and Dang, ZhiChao and Duquesne, Sabine and Sahm, René and Hoffmann, Frauke and Hollert, Henner and Jacob, Stefanie and Klüver, Nils and Lazorchak, James M. and Ledesma, Mariana and Melvin, Steven D. and Mohr, Silvia and Padilla, Stephanie and Pyle, Gregory G. and Scholz, Stefan and Saaristo, Minna and Smit, Els and Steevens, Jeffery A. and family=Berg, given=Sanne, prefix=van den, useprefix=true and Kloas, Werner and Wong, Bob B.M. and Ziegler, Michael and Maack, Gerd},
