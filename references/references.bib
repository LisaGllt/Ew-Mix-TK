@article{jager_2023a,
  title = {Using the Standard {{DEB}} Animal Model for Toxicokinetic-Toxicodynamic Analysis},
  author = {Jager, Tjalling and Goussen, Benoit and Gergs, Andr{\'e}},
  year = 2023,
  month = jan,
  journal = {Ecological Modelling},
  volume = {475},
  pages = {110187},
  issn = {03043800},
  doi = {10.1016/j.ecolmodel.2022.110187},
  urldate = {2023-11-03},
  abstract = {Toxicokinetic-toxicodynamic (TKTD) models are essential tools to close the gap between laboratory toxicity tests and impacts on individuals under field conditions. For sub-lethal effects on life-history traits, dynamic energy budget (DEB) theory provides a solid basis for TKTD modelling. Various DEB-based TKTD models have been presented, ranging from complex and comprehensive to simple and reduced. Here we present a complete and up-to-date model formulation at the complex end of the range. The basic part of the model, governing the life cycle of the species without toxicant stress, is formed by the standard DEB animal model. This part can directly use the species-specific model parameters from the add-my-pet (AmP) library. Additionally, we cover one extension of the standard model with metabolic acceleration for some time after birth (the abj-model). The basic DEB model is augmented by a TKTD model that explicitly considers damage as driving force for the toxic effects, and which considers various feedbacks from life-history traits to damage dynamics (e.g., dilution by growth). Several choices are needed in this linkage, which are made explicit. A Matlab-based toolbox is presented to support the model analyses, which is illustrated with a case study for the springtail Folsomia candida exposed to chlorpyrifos in food.},
  langid = {english},
  file = {/Users/lisagollot/Zotero/storage/GVBEB289/Jager et al. - 2023 - Using the standard DEB animal model for toxicokine.pdf;/Users/lisagollot/Zotero/storage/YNC7TBPS/Jager et al. - Supporting information for Using the standard DEB.pdf}
}

@article{jager_2025,
  title = {It's about Time: Moving Away from Statistical Analysis of Ecotoxicity Data},
  shorttitle = {It's about Time},
  author = {Jager, Tjalling},
  year = 2025,
  month = jan,
  journal = {Integrated Environmental Assessment and Management},
  issn = {1551-3777, 1551-3793},
  doi = {10.1093/inteam/vjaf009},
  urldate = {2025-11-24},
  abstract = {Abstract             Environmental risk assessment (ERA) of chemicals relies on single-species laboratory testing to establish the toxic properties of a compound. However, ERA is not concerned with toxicity under laboratory conditions: it needs to assess the impacts of the compound in the real world. Data-driven statistical analyses (e.g., hypothesis testing and interpolation) are the common approaches for analyzing toxicity data, but such approaches are the wrong tool for the job at hand. Environmental risk assessment does not need a statistical description of the effects in the toxicity test (at the end of the standardized test duration); it needs to extrapolate from the laboratory test to longer and time-varying exposure. Such extrapolation requires mechanistic process models, providing a simplified representation of the mechanisms underlying toxicity. Any useful model for the toxicity process should explicitly consider both dose (e.g., exposure concentration) and time. In the history of effects analysis for ERA, the factor of time does not get as much attention as the dose, hence the common use of the term ``dose-response analysis.'' However, this is a historical oversight: time is a crucial factor for understanding toxicity and thereby essential for meaningful extrapolation from laboratory to field. Mechanistic models for ecotoxicity, considering both dose and time, have been around for quite some time and are classified as toxicokinetic-toxicodynamic (TKTD) models. Toxicokinetic-toxicodynamic models are starting to find their way into pesticide ERA in Europe next to the classical statistical approaches. In this opinion paper, I argue that it is about time to leave statistical analysis of toxicity data behind us. Statistics remains important for ERA effects assessment, but its role lies in the definition of appropriate ``error models,'' explaining the deviations between model output and observations, which is essential for parameter estimation, uncertainty quantification, and error propagation. The ``process model,'' essential for extrapolation, firmly belongs to TKTD modeling.},
  copyright = {https://academic.oup.com/pages/standard-publication-reuse-rights},
  langid = {english},
  file = {/Users/lisagollot/Zotero/storage/HNZ564PD/Jager - 2025 - It’s about time moving away from statistical analysis of ecotoxicity data.pdf}
}

